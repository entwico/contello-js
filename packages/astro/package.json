{
  "name": "@contello/astro",
  "version": "1.0.0",
  "description": "Astro integration for Contello CMS — route middleware and i18n bridge",
  "type": "module",
  "license": "MIT",
  "author": "admin@entwico.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/entwico/contello-js",
    "directory": "packages/astro"
  },
  "scripts": {
    "build": "tsup",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@astroscope/excludes": ">=0.1.0",
    "@astroscope/i18n": ">=0.3.0",
    "astro": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "@astroscope/i18n": {
      "optional": true
    }
  },
  "dependencies": {
    "@contello/client": "workspace:*",
    "@contello/store": "workspace:*"
  },
  "devDependencies": {
    "@astroscope/excludes": "^0.3.0",
    "@astroscope/i18n": "^0.4.0",
    "astro": "^6.0.4"
  },
  "files": [
    "dist"
  ],
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
