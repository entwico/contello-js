{
  "name": "@contello/media",
  "version": "0.0.0",
  "description": "Asset primitives and rendering helpers for Contello CMS (images, videos, files)",
  "type": "module",
  "license": "MIT",
  "author": "admin@entwico.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/entwico/contello-js",
    "directory": "packages/media"
  },
  "scripts": {
    "build": "tsup",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "hls.js": ">=1.5.0",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "hls.js": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "hls.js": "^1.5.0",
    "react": "^19.0.0"
  },
  "files": [
    "dist",
    "fragments"
  ],
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./fragments": {
      "import": "./dist/fragments.js",
      "types": "./dist/fragments.d.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
