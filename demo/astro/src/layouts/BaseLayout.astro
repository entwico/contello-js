---
import { I18nScript } from '@astroscope/i18n/astro';

export type BaseLayoutProps = {
  title: string;
};

type Props = BaseLayoutProps;

const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    <I18nScript />

    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>
